							}
						}
					}
				}
			}
		},
		"/users/by-email/{email}": {
			"get": {
				"operationId": "GetUserByEmail",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"allOf": [
										{
											"$ref": "#/components/schemas/IUser"
										}
									],
									"nullable": true
								}
							}
						}
					}
				},
				"description": "Get a single user by email\r\nAPI này tạo phụ để test nhanh việc get User bằng DB",

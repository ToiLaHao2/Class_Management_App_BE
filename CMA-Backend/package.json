{
  "name": "cma-backend-root",
  "version": "1.0.0",
  "description": "Root of CMA Backend Monorepo",
  "private": true,
  "scripts": {
    "install:all": "npm install",
    "tsoa:spec": "tsoa spec",
    "tsoa:routes": "tsoa routes",
    "tsoa:gen": "tsoa spec && tsoa routes",
    "dev:gateway": "npm run dev -w apps/api-gateway",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:socket": "npm run dev -w apps/socket",
    "dev": "npm run tsoa:gen && concurrently \"npm run dev:gateway\" \"npm run dev:worker\" \"npm run dev:socket\" --names \"GATEWAY,WORKER,SOCKET\" --prefix-colors \"blue,yellow,magenta\""
  },
  "workspaces": [
    "apps/*",
    "libs/core/*",
    "libs/modules/*"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/lru-cache": "^7.10.9",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-emitter": "^5.1.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "socket.io-client": "^4.8.3",
    "tsoa": "^7.0.0-alpha.0"
  }
}

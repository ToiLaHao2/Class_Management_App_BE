# config server
NODE_ENV
PORT

# secret
JWT_SECRET
JWT_EXPIRES_IN

# database config
# PostgreSQL (primary)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cma_db
PG_USER=postgres
PG_PASSWORD=

# PostgreSQL SSL (set to "true" for cloud-hosted PG like Supabase/Neon)
PG_SSL=false

# firebase config (optional — kept for hybrid mode)
FIREBASE_CREDENTIALS

# storage config
# cloudinary config
CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET

# admin seed data
ADMIN_EMAIL
ADMIN_DEFAULT_PASSWORD

# redis config
REDIS_HOST
REDIS_PORT
REDIS_PASSWORD

# redis tls if need
REDIS_TLS

# Storage Provider (local | cloudflare_r2 | cloudinary | aws_s3)
STORAGE_PROVIDER=local
